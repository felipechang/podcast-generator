# Copy to .env and adjust. Loaded from the project root (see podcast_generator.config).

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=glm-4.7-flash:latest
OLLAMA_TEMPERATURE=0.7
OLLAMA_TIMEOUT_S=600

# --- Dialogue tags (LLM must use these exact names in [Name] lines) ---
SPEAKER_1_NAME=Ana
SPEAKER_2_NAME=Carlos

# --- Voice cloning: paths to reference WAV files (repo root relative; Docker: /voices/Ana.wav) ---
SPEAKER_1_VOICE=voices/Ana.wav
SPEAKER_2_VOICE=voices/Carlos.wav

# --- Chatterbox TTS ---
TTS_DEFAULT_LANGUAGE=es
TTS_MODEL_ID=ResembleAI/chatterbox-multilingual
TTS_NUM_THREADS=0
TTS_INTEROP_THREADS=1
TTS_WARMUP=true

# --- Task cleanup (seconds before in-memory task results are deleted) ---
TASK_EXPIRATION_SECONDS=3600
